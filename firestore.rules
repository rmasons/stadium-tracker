rules_version = '2';

// Security model for the stadium tracker.
//
// Trackers are meant to be shareable, so profiles and visits are world-READABLE.
// Writes are locked to the authenticated owner. The public `users/{uid}` doc is
// kept PII-free by rule (only username/displayName/photoURL may be stored) so a
// share page can never leak the owner's email.
service cloud.firestore {
  match /databases/{database}/documents {

    function isOwner(uid) {
      return request.auth != null && request.auth.uid == uid;
    }

    function friendshipId(a, b) {
      return a < b ? a + '_' + b : b + '_' + a;
    }

    function isAcceptedFriend(ownerUid, otherUid) {
      // A single get() call, not exists() + get() — each friend costs one
      // call against Firestore's 10-per-request get()/exists() budget, so
      // this is what makes checking up to 10 friendUids fit at all. get() on
      // a nonexistent friendship doc errors accessing .data, which Firestore
      // rules evaluate as a deny (the correct direction for a missing/
      // unaccepted friendship).
      let path = /databases/$(database)/documents/friendships/$(friendshipId(ownerUid, otherUid));
      return get(path).data.status == 'accepted';
    }

    // A uid is fine to keep on the doc as-is (`existingUids` — the doc's
    // friendUids before this write, [] on create) without re-checking
    // friendship status; only a uid newly being ADDED must be an accepted
    // friend right now. Without this grandfathering, unfriending someone
    // already tagged on an old visit would permanently brick every future
    // edit to that visit (even an unrelated field change), since the old
    // rule re-validated the entire list on every write.
    function isExistingOrNewlyAccepted(ownerUid, existingUids, uid) {
      return existingUids.hasAll([uid]) || isAcceptedFriend(ownerUid, uid);
    }

    // Every uid in `uids` must be existing-or-an-accepted-friend of
    // `ownerUid` — otherwise a visit doc (world-readable) could tag any real
    // user as having attended a game without their consent. Rules can't loop
    // over a variable-length list, so this is unrolled up to the field's own
    // size cap (10); a request with more entries already fails that cap
    // first.
    function allAcceptedFriends(ownerUid, existingUids, uids) {
      return uids.size() <= 0 || isExistingOrNewlyAccepted(ownerUid, existingUids, uids[0])
        && (uids.size() <= 1 || isExistingOrNewlyAccepted(ownerUid, existingUids, uids[1]))
        && (uids.size() <= 2 || isExistingOrNewlyAccepted(ownerUid, existingUids, uids[2]))
        && (uids.size() <= 3 || isExistingOrNewlyAccepted(ownerUid, existingUids, uids[3]))
        && (uids.size() <= 4 || isExistingOrNewlyAccepted(ownerUid, existingUids, uids[4]))
        && (uids.size() <= 5 || isExistingOrNewlyAccepted(ownerUid, existingUids, uids[5]))
        && (uids.size() <= 6 || isExistingOrNewlyAccepted(ownerUid, existingUids, uids[6]))
        && (uids.size() <= 7 || isExistingOrNewlyAccepted(ownerUid, existingUids, uids[7]))
        && (uids.size() <= 8 || isExistingOrNewlyAccepted(ownerUid, existingUids, uids[8]))
        && (uids.size() <= 9 || isExistingOrNewlyAccepted(ownerUid, existingUids, uids[9]));
    }

    // A buddyId is a Firestore auto-id (~20 chars); 64 is a generous bound.
    // Bounding both type and size stops a signed-in owner from writing e.g.
    // buddyIds = [one ~1MB string] or a list of large maps/booleans — the
    // list-level size() <= 25 cap alone says nothing about what's inside
    // each slot.
    function validBuddyId(id) {
      return id is string && id.size() >= 1 && id.size() <= 64;
    }

    // Every entry in `ids` must be a validBuddyId. Rules can't loop over a
    // variable-length list, so this is unrolled up to the field's own size
    // cap (25); a request with more entries already fails that cap first.
    function allValidBuddyIds(ids) {
      return ids.size() <= 0 || validBuddyId(ids[0])
        && (ids.size() <= 1 || validBuddyId(ids[1]))
        && (ids.size() <= 2 || validBuddyId(ids[2]))
        && (ids.size() <= 3 || validBuddyId(ids[3]))
        && (ids.size() <= 4 || validBuddyId(ids[4]))
        && (ids.size() <= 5 || validBuddyId(ids[5]))
        && (ids.size() <= 6 || validBuddyId(ids[6]))
        && (ids.size() <= 7 || validBuddyId(ids[7]))
        && (ids.size() <= 8 || validBuddyId(ids[8]))
        && (ids.size() <= 9 || validBuddyId(ids[9]))
        && (ids.size() <= 10 || validBuddyId(ids[10]))
        && (ids.size() <= 11 || validBuddyId(ids[11]))
        && (ids.size() <= 12 || validBuddyId(ids[12]))
        && (ids.size() <= 13 || validBuddyId(ids[13]))
        && (ids.size() <= 14 || validBuddyId(ids[14]))
        && (ids.size() <= 15 || validBuddyId(ids[15]))
        && (ids.size() <= 16 || validBuddyId(ids[16]))
        && (ids.size() <= 17 || validBuddyId(ids[17]))
        && (ids.size() <= 18 || validBuddyId(ids[18]))
        && (ids.size() <= 19 || validBuddyId(ids[19]))
        && (ids.size() <= 20 || validBuddyId(ids[20]))
        && (ids.size() <= 21 || validBuddyId(ids[21]))
        && (ids.size() <= 22 || validBuddyId(ids[22]))
        && (ids.size() <= 23 || validBuddyId(ids[23]))
        && (ids.size() <= 24 || validBuddyId(ids[24]));
    }

    function validProfile(data) {
      return data.keys().hasOnly(['username', 'displayName', 'photoURL'])
        && data.username is string
        && data.username.size() >= 3
        && data.username.size() <= 30
        && data.displayName is string
        && data.photoURL is string;
    }

    // Public profile. World-readable; only the owner may write, and only the
    // three allowed, non-PII fields.
    match /users/{uid} {
      allow read: if true;
      allow create, update: if isOwner(uid) && validProfile(request.resource.data);
      allow delete: if false;

      // A user's stadium visits — world-readable (share page), owner-writable.
      // Each visit is its own auto-id doc, so a stadium can be logged many
      // times; stadiumId is a field, not the document id.
      match /visits/{visitId} {
        allow read: if true;
        allow create: if isOwner(uid)
          && request.resource.data.stadiumId is string
          && request.resource.data.stadiumId.size() > 0
          && request.resource.data.league in ['MLB', 'NFL']
          && request.resource.data.date is string
          && request.resource.data.opponent is string
          // buddyIds/friendUids are optional (older clients may omit them)
          // but capped so a malicious client can't stuff megabytes of ids
          // into this world-readable doc. It's not enough to cap the list's
          // size() — each entry must also be individually validated, or a
          // signed-in owner could still write e.g. buddyIds = [one ~1MB
          // string] or a list of large maps/booleans. buddyIds is checked
          // entry-by-entry via allValidBuddyIds (each must be a bounded
          // string); friendUids is capped at 10 (not 25) because every
          // entry must additionally be individually confirmed as an
          // accepted friend via allAcceptedFriends — both helpers unrolled
          // to their respective caps since rules can't loop over a
          // variable-length list.
          && (!('buddyIds' in request.resource.data)
              || (request.resource.data.buddyIds is list
                  && request.resource.data.buddyIds.size() <= 25
                  && allValidBuddyIds(request.resource.data.buddyIds)))
          && (!('friendUids' in request.resource.data)
              || (request.resource.data.friendUids is list
                  && request.resource.data.friendUids.size() <= 10
                  && allAcceptedFriends(uid, [], request.resource.data.friendUids)));
        // Updates may not move a visit to a different stadium. friendUids
        // already on the doc are grandfathered (see isExistingOrNewlyAccepted)
        // so an update doesn't re-validate friendships that may since have
        // ended — only newly-added uids must be accepted friends right now.
        allow update: if isOwner(uid)
          && request.resource.data.stadiumId == resource.data.stadiumId
          && request.resource.data.date is string
          && request.resource.data.opponent is string
          && (!('buddyIds' in request.resource.data)
              || (request.resource.data.buddyIds is list
                  && request.resource.data.buddyIds.size() <= 25
                  && allValidBuddyIds(request.resource.data.buddyIds)))
          && (!('friendUids' in request.resource.data)
              || (request.resource.data.friendUids is list
                  && request.resource.data.friendUids.size() <= 10
                  && allAcceptedFriends(
                       uid,
                       ('friendUids' in resource.data) ? resource.data.friendUids : [],
                       request.resource.data.friendUids)));
        allow delete: if isOwner(uid);
      }

      // Buddies: named companions, strictly private to the owner (no world
      // read — buddy names are personal data, unlike the public profile).
      match /buddies/{buddyId} {
        allow read, delete: if isOwner(uid);
        allow create, update: if isOwner(uid)
          && request.resource.data.keys().hasOnly(['name', 'createdAt'])
          && request.resource.data.name is string
          && request.resource.data.name.size() >= 1
          && request.resource.data.name.size() <= 50
          && request.resource.data.createdAt is number;
      }
    }

    // Friendships: one doc per pair at friendships/{pairId}, where
    // pairId = sorted UIDs joined by '_'. A pending doc is a friend request;
    // accepting flips it in place. Readable only by the two members.
    match /friendships/{friendshipId} {
      // Get must work on a NONEXISTENT doc too: sendFriendRequest does a
      // pre-create existence check, and referencing resource.data when
      // resource is null errors (→ permission-denied). Gate the null case on
      // the caller's uid appearing in the doc ID instead. Safe: Firebase Auth
      // UIDs are alphanumeric and never contain '_'.
      allow get: if request.auth != null
        && (resource == null
            ? request.auth.uid in friendshipId.split('_')
            : request.auth.uid in resource.data.members);
      // List = the members array-contains-uid subscription.
      allow list: if request.auth != null
        && request.auth.uid in resource.data.members;
      // Create = send request: caller must be a member and the requester.
      // members[0] < members[1] enforces sorted AND distinct (no
      // self-friending), and binding friendshipId to members prevents
      // squatting another pair's ID to block them from ever connecting.
      allow create: if request.auth != null
        && request.resource.data.keys().hasOnly(
             ['members', 'requestedBy', 'status', 'createdAt', 'updatedAt'])
        && request.resource.data.members.size() == 2
        && request.resource.data.members[0] < request.resource.data.members[1]
        && friendshipId ==
             request.resource.data.members[0] + '_' + request.resource.data.members[1]
        && request.auth.uid in request.resource.data.members
        && request.resource.data.requestedBy == request.auth.uid
        && request.resource.data.status == 'pending'
        && request.resource.data.createdAt is number
        && request.resource.data.updatedAt is number;
      // Update = accept only: the non-requester flips pending→accepted;
      // members/requestedBy/createdAt are immutable.
      allow update: if request.auth != null
        && request.auth.uid in resource.data.members
        && resource.data.status == 'pending'
        && request.resource.data.status == 'accepted'
        && request.auth.uid != resource.data.requestedBy
        && request.resource.data.members == resource.data.members
        && request.resource.data.requestedBy == resource.data.requestedBy
        && request.resource.data.createdAt == resource.data.createdAt
        && request.resource.data.updatedAt is number;
      // Delete: either member (unfriend, decline, or cancel).
      allow delete: if request.auth != null
        && request.auth.uid in resource.data.members;
    }

    // Username registry: usernames/{username} -> { uid }. Used for uniqueness
    // and to resolve a share URL to a uid.
    match /usernames/{username} {
      allow read: if true;
      // Claim: the doc must not already exist (create), hold only { uid }, and
      // point to the caller. This is what makes usernames unique.
      allow create: if request.auth != null
        && request.resource.data.keys().hasOnly(['uid'])
        && request.resource.data.uid == request.auth.uid;
      // Release a handle you own (used when renaming).
      allow delete: if request.auth != null
        && resource.data.uid == request.auth.uid;
      allow update: if false;
    }
  }
}
