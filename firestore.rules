rules_version = '2';

// Security model for the stadium tracker.
//
// Trackers are meant to be shareable, so profiles and visits are world-READABLE.
// Writes are locked to the authenticated owner. The public `users/{uid}` doc is
// kept PII-free by rule (only username/displayName/photoURL may be stored) so a
// share page can never leak the owner's email.
service cloud.firestore {
  match /databases/{database}/documents {

    function isOwner(uid) {
      return request.auth != null && request.auth.uid == uid;
    }

    function validProfile(data) {
      return data.keys().hasOnly(['username', 'displayName', 'photoURL'])
        && data.username is string
        && data.username.size() >= 3
        && data.username.size() <= 30
        && data.displayName is string
        && data.photoURL is string;
    }

    // Public profile. World-readable; only the owner may write, and only the
    // three allowed, non-PII fields.
    match /users/{uid} {
      allow read: if true;
      allow create, update: if isOwner(uid) && validProfile(request.resource.data);
      allow delete: if false;

      // A user's stadium visits — world-readable (share page), owner-writable.
      // Each visit is its own auto-id doc, so a stadium can be logged many
      // times; stadiumId is a field, not the document id.
      match /visits/{visitId} {
        allow read: if true;
        allow create: if isOwner(uid)
          && request.resource.data.stadiumId is string
          && request.resource.data.stadiumId.size() > 0
          && request.resource.data.league in ['MLB', 'NFL']
          && request.resource.data.date is string
          && request.resource.data.opponent is string
          // buddyIds/friendUids are optional (older clients may omit them)
          // but capped so a malicious client can't stuff megabytes of ids
          // into this world-readable doc.
          && (!('buddyIds' in request.resource.data)
              || (request.resource.data.buddyIds is list
                  && request.resource.data.buddyIds.size() <= 25))
          && (!('friendUids' in request.resource.data)
              || (request.resource.data.friendUids is list
                  && request.resource.data.friendUids.size() <= 25));
        // Updates may not move a visit to a different stadium.
        allow update: if isOwner(uid)
          && request.resource.data.stadiumId == resource.data.stadiumId
          && request.resource.data.date is string
          && request.resource.data.opponent is string
          && (!('buddyIds' in request.resource.data)
              || (request.resource.data.buddyIds is list
                  && request.resource.data.buddyIds.size() <= 25))
          && (!('friendUids' in request.resource.data)
              || (request.resource.data.friendUids is list
                  && request.resource.data.friendUids.size() <= 25));
        allow delete: if isOwner(uid);
      }

      // Buddies: named companions, strictly private to the owner (no world
      // read — buddy names are personal data, unlike the public profile).
      match /buddies/{buddyId} {
        allow read, delete: if isOwner(uid);
        allow create, update: if isOwner(uid)
          && request.resource.data.keys().hasOnly(['name', 'createdAt'])
          && request.resource.data.name is string
          && request.resource.data.name.size() >= 1
          && request.resource.data.name.size() <= 50
          && request.resource.data.createdAt is number;
      }
    }

    // Friendships: one doc per pair at friendships/{pairId}, where
    // pairId = sorted UIDs joined by '_'. A pending doc is a friend request;
    // accepting flips it in place. Readable only by the two members.
    match /friendships/{friendshipId} {
      // Get must work on a NONEXISTENT doc too: sendFriendRequest does a
      // pre-create existence check, and referencing resource.data when
      // resource is null errors (→ permission-denied). Gate the null case on
      // the caller's uid appearing in the doc ID instead. Safe: Firebase Auth
      // UIDs are alphanumeric and never contain '_'.
      allow get: if request.auth != null
        && (resource == null
            ? request.auth.uid in friendshipId.split('_')
            : request.auth.uid in resource.data.members);
      // List = the members array-contains-uid subscription.
      allow list: if request.auth != null
        && request.auth.uid in resource.data.members;
      // Create = send request: caller must be a member and the requester.
      // members[0] < members[1] enforces sorted AND distinct (no
      // self-friending), and binding friendshipId to members prevents
      // squatting another pair's ID to block them from ever connecting.
      allow create: if request.auth != null
        && request.resource.data.keys().hasOnly(
             ['members', 'requestedBy', 'status', 'createdAt', 'updatedAt'])
        && request.resource.data.members.size() == 2
        && request.resource.data.members[0] < request.resource.data.members[1]
        && friendshipId ==
             request.resource.data.members[0] + '_' + request.resource.data.members[1]
        && request.auth.uid in request.resource.data.members
        && request.resource.data.requestedBy == request.auth.uid
        && request.resource.data.status == 'pending'
        && request.resource.data.createdAt is number
        && request.resource.data.updatedAt is number;
      // Update = accept only: the non-requester flips pending→accepted;
      // members/requestedBy/createdAt are immutable.
      allow update: if request.auth != null
        && request.auth.uid in resource.data.members
        && resource.data.status == 'pending'
        && request.resource.data.status == 'accepted'
        && request.auth.uid != resource.data.requestedBy
        && request.resource.data.members == resource.data.members
        && request.resource.data.requestedBy == resource.data.requestedBy
        && request.resource.data.createdAt == resource.data.createdAt
        && request.resource.data.updatedAt is number;
      // Delete: either member (unfriend, decline, or cancel).
      allow delete: if request.auth != null
        && request.auth.uid in resource.data.members;
    }

    // Username registry: usernames/{username} -> { uid }. Used for uniqueness
    // and to resolve a share URL to a uid.
    match /usernames/{username} {
      allow read: if true;
      // Claim: the doc must not already exist (create), hold only { uid }, and
      // point to the caller. This is what makes usernames unique.
      allow create: if request.auth != null
        && request.resource.data.keys().hasOnly(['uid'])
        && request.resource.data.uid == request.auth.uid;
      // Release a handle you own (used when renaming).
      allow delete: if request.auth != null
        && resource.data.uid == request.auth.uid;
      allow update: if false;
    }
  }
}
